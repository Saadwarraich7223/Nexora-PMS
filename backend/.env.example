# Core
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/pms

# JWT
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CLIENT_ORIGIN=http://localhost:3000

# Default Admin
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_PASSWORD_HASH=

# Email
MAIL_FROM=FYPMS <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
UNIVERSITY_NAME=University

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Supervisor
SUPERVISOR_DEFAULT_CAPACITY=6

# Contribution Weights
CONTRIBUTION_TASK_WEIGHT=0.35
CONTRIBUTION_FEATURE_WEIGHT=0.25
CONTRIBUTION_REPORT_WEIGHT=0.2
CONTRIBUTION_PEER_WEIGHT=0.2
